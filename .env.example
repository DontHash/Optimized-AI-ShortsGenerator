# LLM provider for highlight ranking
LLM_PROVIDER=openai           # openai or gemini
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash

# Whisper
LOCAL_WHISPER_MODEL=base      # tiny / base / small / medium / large-v3
LOCAL_WHISPER_DEVICE=auto     # auto / cpu / cuda

# Output / download
LOCAL_OUTPUT_DIR=output
DOWNLOAD_FORMAT=max           # max (uncapped) | 360 / 480 / 720 / 1080

# Signal-fusion reranker (see UPLIFT_PLAN.md) — missing signals renormalize
RERANK_WEIGHTS=llm:0.45,replay:0.25,audio:0.20,chapter:0.10
AUDIO_ENERGY=true             # ffmpeg+numpy loudness/spike/pause scoring
DEDUPE_SIMILARITY=0.6         # drop clips whose transcripts overlap more than this

# Context-aware peak expansion (capture the setup that leads into a replay peak)
PEAK_LEAD_SECONDS=5           # minimum lead-in before a peak
PEAK_LEAD_MAX_SECONDS=20      # cap on how far back to reach for setup
PEAK_TAIL_SECONDS=5           # padding after the peak/payoff
MAX_CLIP_SECONDS=180          # hard ceiling; tail trimmed first, lead-in kept

# Captions (used by captions.py)
CAPTION_FONT=Arial
CAPTION_FONT_SIZE=48
CAPTION_HIGHLIGHT_COLOR=&H0000FFFF
CAPTION_MAX_WORDS=3
